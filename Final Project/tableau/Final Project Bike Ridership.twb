      <column caption='Season ' datatype='string' name='[Calculation_1997909401121079296]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [assigned_month] IN (12, 1, 2) THEN &quot;Winter&quot;&#13;&#10;ELSEIF [assigned_month] IN (3, 4, 5) THEN &quot;Spring&quot;&#13;&#10;ELSEIF [assigned_month] IN (6, 7, 8) THEN &quot;Summer&quot;&#13;&#10;ELSEIF [assigned_month] IN (9, 10, 11) THEN &quot;Fall&quot;&#13;&#10;END' />
      </column>
      <column aggregation='Count' caption='Average Trip Duration Mins' datatype='real' name='[Calculation_1997909401187491845]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sum_min] / [num_trip]' />
      </column>
